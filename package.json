{
  "name": "last-minute-life-server",
  "version": "1.0.0",
  "description": "Full-stack web app for Last Minute Life Server decisions and services.",
  "main": "src/server.js",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "next dev",
    "dev:api": "nodemon src/server.js",
    "build": "next build",
    "start:web": "next start",
    "create-admin": "node src/utils/createAdmin.js",
    "lint": "eslint src --max-warnings=0"
  },
  "keywords": [
    "express",
    "mongodb",
    "gaming-server",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.9",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
